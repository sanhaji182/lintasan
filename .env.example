# Lintasan Go — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Required ===

# Port for the Go server (default: 20180)
PORT=20180

# Directory for SQLite database and runtime data
LINTASAN_DATA_DIR=./data

# Master API key — clients use this to authenticate proxy requests
# Generate a strong key: openssl rand -hex 32
LINTASAN_MASTER_KEY=

# === Optional ===

# Redis address for vector memory (default: 127.0.0.1:6379)
# Lintasan gracefully degrades if Redis is unavailable
REDIS_ADDR=127.0.0.1:6379

# MITM proxy port for IDE traffic interception (default: 8443)
MITM_PORT=8443

# === Dashboard (if using external dashboard) ===

# Dashboard URL for reverse-proxy (default: http://127.0.0.1:20180)
# Set to empty to disable dashboard proxy
DASHBOARD_URL=
