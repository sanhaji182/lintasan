{"_comment":"GitHub Copilot CLI spec-ACP fixture SKELETON (Cohort-A readiness). Drives the Generic ACP Framework's Protocol+Acceptance gates in-process via the provider-agnostic replay agent. NOT a recording of the real copilot --acp binary — the real wire contract AND the auth model (Copilot may use device auth / a GitHub token rather than a plain API-key env var) are UNVERIFIED and MUST be confirmed against the real binary at Copilot's own live validation. Shape mirrors the reconciled spec ACP lifecycle: initialize -> authenticate -> session/new -> session/prompt (agent_message_chunk + tool_call + request_permission + terminal stopReason)."}
{"on":"initialize","emit":[{"jsonrpc":"2.0","id":"__ID__","result":{"protocolVersion":1,"agentInfo":{"name":"copilot","version":"skeleton"},"agentCapabilities":{"promptCapabilities":{"image":false}},"authMethods":[{"type":"env_var","id":"github-token","name":"Use GITHUB_TOKEN"}]}}]}
{"on":"authenticate","emit":[{"jsonrpc":"2.0","id":"__ID__","result":{}}]}
{"on":"session/new","emit":[{"jsonrpc":"2.0","id":"__ID__","result":{"sessionId":"sess-copilot-skeleton"}}]}
{"on":"session/prompt","emit":[{"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"sess-copilot-skeleton","update":{"sessionUpdate":"agent_message_chunk","content":{"type":"text","text":"Editing the file."}}}},{"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"sess-copilot-skeleton","update":{"sessionUpdate":"tool_call","toolCallId":"cop_call_001","kind":"edit","status":"pending","title":"apply edit"}}},{"jsonrpc":"2.0","id":"perm-copilot-1","method":"session/request_permission","params":{"sessionId":"sess-copilot-skeleton","toolCallId":"cop_call_001","options":[{"optionId":"allow-once","name":"Allow once","kind":"allow_once"},{"optionId":"reject-once","name":"Reject","kind":"reject_once"}]}},{"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"sess-copilot-skeleton","update":{"sessionUpdate":"tool_call_update","toolCallId":"cop_call_001","status":"completed"}}},{"jsonrpc":"2.0","id":"__PROMPT_ID__","result":{"stopReason":"end_turn"}}]}
{"on":"shutdown","emit":[{"jsonrpc":"2.0","id":"__ID__","result":{}}]}
