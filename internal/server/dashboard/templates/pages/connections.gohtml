{{define "pages/connections.gohtml"}}
<div x-data="{
  showModal: false,
  modalTitle: 'Add Provider',
  editMode: false,
  editId: '',
  selectedPreset: null,
  presets: [],
  connections: null,
  form: { name: '', provider: '', api_key: '', base_url: '', models: '' }
}" x-init="fetchConnections()">
  <div class="flex items-center justify-between mb-5">
    <div>
      <h1 class="text-xl font-bold text-[var(--color-fg-0)]">🔌 Provider Accounts</h1>
      <p class="text-sm text-[var(--color-fg-2)]">Manage connections to AI model providers.</p>
    </div>
    <button class="btn btn-primary" x-on:click="showModal = true; modalTitle = 'Add Provider'; editMode = false; selectedPreset = null; form = { name: '', provider: '', api_key: '', base_url: '', models: '' }; $nextTick(() => $refs.presetsGrid && loadPresets())">+ Add Provider</button>
  </div>

  <!-- Connections Table -->
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Provider</th>
          <th>Models</th>
          <th>Status</th>
          <th>Latency</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <template x-if="!connections">
          <tr><td colspan="6" class="text-center p-6"><div class="spinner mx-auto"></div></td></tr>
        </template>
        <template x-if="connections && connections.length === 0">
          <tr><td colspan="6" class="text-center p-6"><div class="empty-state"><p>No connections yet</p></div></td></tr>
        </template>
        <template x-for="conn in connections" :key="conn.id">
          <tr>
            <td class="text-sm font-medium" x-text="conn.name"></td>
            <td class="text-xs text-[var(--color-fg-2)]" x-text="conn.provider"></td>
            <td class="text-xs text-[var(--color-fg-2)]" x-text="conn.models_count || '—'"></td>
            <td><span class="badge" :class="conn.is_active ? 'badge-success' : 'badge-danger'" x-text="conn.is_active ? 'Active' : 'Inactive'"></span></td>
            <td class="text-xs text-[var(--color-fg-2)]" x-text="conn.latency_ms ? conn.latency_ms + 'ms' : '—'"></td>
            <td>
              <button class="btn btn-ghost btn-sm" x-on:click="editConnection(conn)">Edit</button>
              <button class="btn btn-ghost btn-sm text-red-500" x-on:click="deleteConnection(conn.id)">Delete</button>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>

  <!-- Add/Edit Provider Modal -->
  <template x-if="showModal">
    <div>
      <div class="modal-backdrop" x-on:click="showModal = false"></div>
      <div class="max-w-[640px] modal-panel" x-on:click.outside="showModal = false">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-semibold text-[var(--color-fg-0)]" x-text="modalTitle"></h2>
          <button class="btn-icon text-lg" x-on:click="showModal = false">&times;</button>
        </div>

        <!-- Preset Grid (only when adding) -->
        <template x-if="!editMode && !selectedPreset">
          <div>
            <p class="text-sm text-[var(--color-fg-2)] mb-3">Choose a provider preset to get started:</p>
            <div x-ref="presetsGrid" id="presets-grid" class="grid grid-cols-2 gap-2 mb-4">
            </div>
            <button class="btn btn-ghost" x-on:click="selectedPreset = { provider: 'custom', name: '' }; form.provider = 'custom'">Manual Configuration</button>
          </div>
        </template>

        <!-- Manual form (after preset or edit) -->
        <template x-if="selectedPreset || editMode">
          <form x-on:submit="saveConnection()">
            <template x-if="editMode">
              <input type="hidden" name="id" x-bind:value="editId">
            </template>
            <label>Display Name</label>
            <input type="text" name="name" x-model="form.name" placeholder="e.g., OpenAI Production">

            <label>Provider</label>
            <input type="text" name="provider" x-model="form.provider" placeholder="openai">

            <label>API Key</label>
            <input type="password" name="api_key" x-model="form.api_key" placeholder="sk-...">

            <label>Base URL (optional)</label>
            <input type="text" name="base_url" x-model="form.base_url" placeholder="https://api.openai.com/v1">

            <label>Models (comma-separated)</label>
            <input type="text" name="models" x-model="form.models" placeholder="gpt-4o, gpt-4o-mini">

            <div class="flex gap-2 mt-4">
              <button type="button" class="btn btn-secondary"
                      x-on:click="testConnection()">
                Test Connection
              </button>
              <div id="test-result" class="flex items-center text-sm"></div>
            </div>
            <div class="flex gap-2 justify-end mt-4">
              <button type="button" class="btn btn-secondary" x-on:click="selectedPreset = null; if (editMode) { showModal = false }">Back</button>
              <button type="submit" class="btn btn-primary" x-bind:disabled="!form.name.trim() || !form.provider.trim()">Save</button>
            </div>
          </form>
        </template>
      </div>
    </div>
  </template>

  <script>
    function loadPresets() {
      var grid = document.getElementById('presets-grid');
      if (!grid) return;
      grid.innerHTML = '<div class="col-span-full mx-auto spinner"></div>';
      fetch('/api/providers/presets')
        .then(r => r.json())
        .then(data => {
          if (Array.isArray(data)) {
            grid.innerHTML = data.map(p =>
              '<button type="button" class="btn btn-secondary btn-sm justify-start p-2" ' +
              'onclick="var d=Alpine.$data(document.querySelector(\'[x-data]\')); ' +
              'd.selectedPreset = ' + JSON.stringify(p).replace(/"/g, '&quot;') + '; ' +
              'd.form = { name: \'' + (p.name || p.provider).replace(/'/g, "\\'") + '\', provider: \'' + (p.provider || '').replace(/'/g, "\\'") + '\', api_key: \'\', base_url: \'' + (p.base_url || '').replace(/'/g, "\\'") + '\', models: \'\' };">' +
              (p.icon || '🔌') + ' ' + (p.label || p.provider || p.name) +
              '</button>'
            ).join('');
          }
        })
        .catch(() => {
          grid.innerHTML = '<span>Failed to load presets</span>';
        });
    }

    async function fetchConnections() {
      try {
        let r = await fetch('/api/connections');
        if (r.ok) {
          let data = await r.json();
          this.connections = data || [];
        }
      } catch(e) { console.error('Connections fetch failed', e); }
    }

    function editConnection(conn) {
      this.showModal = true;
      this.modalTitle = 'Edit Provider';
      this.editMode = true;
      this.editId = conn.id;
      this.form = {
        name: conn.name || '',
        provider: conn.provider || '',
        api_key: '',
        base_url: conn.base_url || '',
        models: ''
      };
      this.selectedPreset = { provider: conn.provider, name: conn.name };
    }

    async function saveConnection() {
      try {
        let method = this.editMode ? 'PUT' : 'POST';
        let r = await fetch('/api/connections', {
          method: method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(this.form)
        });
        if (r.ok) {
          this.showModal = false;
          this.fetchConnections();
        }
      } catch(e) { console.error('Save connection failed', e); }
    }

    async function deleteConnection(id) {
      if (!confirm('Delete this connection?')) return;
      try {
        let r = await fetch('/api/connections?id=' + id, { method: 'DELETE' });
        if (r.ok) {
          this.fetchConnections();
        }
      } catch(e) { console.error('Delete connection failed', e); }
    }

    async function testConnection() {
      let result = document.getElementById('test-result');
      result.innerHTML = '<span class="spinner mr-2"></span> Testing...';
      try {
        let r = await fetch('/api/connections/test', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(this.form)
        });
        if (r.ok) {
          result.innerHTML = '<span class="text-green-500">✓ Success</span>';
        } else {
          result.innerHTML = '<span class="text-red-500">✗ Failed</span>';
        }
      } catch(e) {
        result.innerHTML = '<span class="text-red-500">✗ Error</span>';
      }
    }
  </script>
</div>
{{end}}
